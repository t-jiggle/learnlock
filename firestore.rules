rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /children/{childId} {
      // Any request can read a child profile by ID — needed so the child device
      // can look up the profile from the QR code *before* signing in.
      // The profile ID is a UUIDv4, making it effectively unguessable.
      allow read: if true;

      // Only the parent may create a profile for their own account.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.parentUid;

      allow update: if request.auth != null && (
        // Parent can update any field.
        request.auth.uid == resource.data.parentUid

        // Linked child may update only the three fields the app writes on their
        // behalf: screenTimeExpiresAt (session completion), lastSeenAt and
        // devicePlatform (device reporting). Restricting to these fields prevents
        // a child from editing learning requirements.
        || (
          request.auth.token.email == resource.data.googleAccountId
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['screenTimeExpiresAt', 'lastSeenAt', 'devicePlatform'])
        )

        // Any authenticated user may perform the *initial* account link:
        // setting googleAccountId from null/empty, and changing only that field.
        || (
          (resource.data.googleAccountId == null || resource.data.googleAccountId == '')
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['googleAccountId'])
        )
      );

      allow delete: if false;
    }

    // Parents and the linked child can read/write progress records.
    match /progress/{childId} {
      allow read, write: if request.auth != null && (
        request.auth.uid ==
          get(/databases/(default)/documents/children/$(childId)).data.parentUid
        || request.auth.token.email ==
          get(/databases/(default)/documents/children/$(childId)).data.googleAccountId
      );
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
